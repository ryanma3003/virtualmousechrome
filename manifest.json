{
  "manifest_version": 3,
  "name": "Virtual Mouse Jiggler",
  "version": "1.0.0",
  "description": "A lightweight virtual mouse jiggler with low-power idle prevention.",
  "permissions": [
    "alarms",
    "power",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Virtual Mouse Jiggler"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
